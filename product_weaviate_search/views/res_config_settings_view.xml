<odoo>

    <record id="res_config_settings_view_form_weaviate" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.weaviate</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
            <app string="Weaviate" name="product_weaviate_search">

                <block title="Connection">
                    <setting string="Deployment Type">
                        <field name="weaviate_deployment_type"/>
                    </setting>

                    <!-- Weaviate Cloud fields -->
                    <setting
                        string="Cluster URL"
                        help="Your Weaviate Cloud cluster URL, e.g. https://xxx.weaviate.cloud"
                        invisible="weaviate_deployment_type != 'cloud'"
                    >
                        <field name="weaviate_url" placeholder="https://xxx.weaviate.cloud"/>
                    </setting>
                    <setting
                        string="Weaviate API Key"
                        help="API key for Weaviate Cloud or secured custom instances."
                    >
                        <field name="weaviate_api_key" password="True"/>
                    </setting>

                    <!-- Custom connection fields -->
                    <setting
                        string="HTTP Host"
                        help="Hostname for the HTTP API, e.g. localhost or weaviate."
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_http_host" placeholder="localhost"/>
                    </setting>
                    <setting
                        string="HTTP Port"
                        help="HTTP port. Typical: 80 (plain) or 443 (TLS)."
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_http_port"/>
                    </setting>
                    <setting
                        string="HTTP Secure (HTTPS)"
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_http_secure"/>
                    </setting>
                    <setting
                        string="gRPC Host"
                        help="Hostname for the gRPC API. Defaults to HTTP host if empty."
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_grpc_host" placeholder="(same as HTTP host)"/>
                    </setting>
                    <setting
                        string="gRPC Port"
                        help="gRPC port. Typical: 50051 (plain) or 443 (TLS)."
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_grpc_port"/>
                    </setting>
                    <setting
                        string="gRPC Secure"
                        invisible="weaviate_deployment_type != 'custom'"
                    >
                        <field name="weaviate_grpc_secure"/>
                    </setting>

                    <!-- Always visible -->
                    <setting
                        string="OpenAI API Key"
                        help="Used for text2vec-openai vectorization. Sent as X-OpenAI-Api-Key header. Optional when Weaviate already has the key via its OPENAI_APIKEY environment variable (Docker Compose stack). Required for Weaviate Cloud or custom deployments without the env var."
                    >
                        <field name="weaviate_openai_api_key" password="True"/>
                    </setting>
                    <setting
                        string="Collection Name"
                        help="Name of the Weaviate collection that stores product vectors."
                    >
                        <field name="weaviate_collection_name" placeholder="OdooProduct"/>
                    </setting>
                </block>

                <block title="Search Features">
                    <setting
                        string="Live Sync"
                        help="Automatically push products to Weaviate on create, update, or delete."
                    >
                        <field name="weaviate_live_sync_enabled"/>
                        <div class="text-muted">
                            Disable during bulk imports or data migrations and
                            use the sync wizard afterwards.
                        </div>
                    </setting>
                    <setting
                        string="Backend Product Search"
                        help="Replace the product list view search bar with Weaviate hybrid search."
                    >
                        <field name="weaviate_backend_search_enabled"/>
                        <div class="text-muted">
                            Enable Weaviate search in the backend product list view.
                        </div>
                    </setting>
                    <setting
                        string="eCommerce Shop Search"
                        help="Replace the /shop search with Weaviate hybrid search."
                    >
                        <field name="weaviate_shop_search_enabled"/>
                        <div class="text-muted">
                            Requires the <em>eCommerce</em> (website_sale) module.
                        </div>
                    </setting>
                </block>

                <block title="Search Tuning">
                    <setting
                        string="Result Limit"
                        help="Maximum number of products returned per search query."
                    >
                        <field name="weaviate_search_limit"/>
                    </setting>
                    <setting
                        string="Hybrid Alpha"
                        help="0.0 = pure BM25 keyword search, 1.0 = pure vector search, 0.5 = balanced."
                    >
                        <field name="weaviate_search_alpha"/>
                    </setting>
                    <setting
                        string="eCommerce Search Limit"
                        help="Maximum products returned in the /shop search. 0 = use the global Result Limit above."
                    >
                        <field name="weaviate_shop_search_limit"/>
                        <div class="text-muted">
                            Set to <strong>0</strong> to inherit the global Result Limit.
                        </div>
                    </setting>
                    <setting
                        string="Autocut"
                        help="Stop returning results after N consecutive drops in relevance score. Applies to backend and eCommerce searches. 0 = disabled."
                    >
                        <field name="weaviate_search_autocut"/>
                        <div class="text-muted">
                            Cuts low-relevance products automatically.
                            Applies to <strong>both</strong> backend and eCommerce searches.
                            <strong>0</strong> disables autocut.
                        </div>
                    </setting>
                </block>

                <block title="Product Sync">
                    <setting
                        string="Sync Products"
                        help="Push products to the Weaviate collection. Run after initial setup or after bulk changes."
                    >
                        <button
                            name="action_open_weaviate_sync_wizard"
                            string="Open Sync Wizard"
                            type="object"
                            class="btn-secondary"
                        />
                        <div class="text-muted">
                            Choose to sync all products, only unsynced ones, or
                            reset the collection and re-index from scratch.
                            You can also sync selected products directly from
                            the product list view via <strong>Action → Sync with Weaviate</strong>.
                        </div>
                    </setting>
                </block>

            </app>
            </xpath>
        </field>
    </record>

</odoo>
