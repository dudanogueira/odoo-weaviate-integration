<!--
    Demo data: pre-fills the Weaviate connection for the included Docker
    Compose development stack (docker/docker-compose.yml).

    After loading this data, only the OpenAI API key needs to be entered
    manually in Settings → Weaviate → OpenAI API Key.

    HTTP and gRPC ports are already seeded at 8080 / 50051 by
    data/ir_config_parameter_data.xml and match the Docker stack defaults.
-->
<odoo>

    <!-- Point both HTTP and gRPC at the Docker service named "weaviate". -->
    <record id="param_http_host_demo" model="ir.config_parameter">
        <field name="key">product_weaviate_search.http_host</field>
        <field name="value">weaviate</field>
    </record>

    <record id="param_grpc_host_demo" model="ir.config_parameter">
        <field name="key">product_weaviate_search.grpc_host</field>
        <field name="value">weaviate</field>
    </record>

</odoo>
